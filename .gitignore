# =============================================================================
# system-baseline .gitignore
# Paranoid by default. This repo captures system state — never let secrets in.
# =============================================================================

# -----------------------------------------------------------------------------
# SSH / GPG keys
# -----------------------------------------------------------------------------
id_*
*.pem
*.key
*.ppk
*.gpg
*.asc
secring.*
**/.gnupg/
**/.ssh/id_*
**/.ssh/known_hosts

# -----------------------------------------------------------------------------
# Cloud credentials
# -----------------------------------------------------------------------------
.aws/credentials
.aws/config
**/kube/config
**/.kube/
**/gcloud/
**/.azure/

# -----------------------------------------------------------------------------
# Env / secret files
# -----------------------------------------------------------------------------
.env
.env.*
*.env
*secrets*
*credentials*

# -----------------------------------------------------------------------------
# Password manager exports
# -----------------------------------------------------------------------------
*.1pux
password*.csv
vault*.csv
**/vault*/

# -----------------------------------------------------------------------------
# Browser state
# -----------------------------------------------------------------------------
**/Cookies*
**/Login Data*
**/Web Data*
**/User Data/

# -----------------------------------------------------------------------------
# Tokens / auth files
# -----------------------------------------------------------------------------
*token*
.netrc
_netrc
.npmrc
.pypirc
**/.config/gh/hosts.yml
**/.config/claude*/auth*
**/.claude/credentials*
**/anthropic*/auth*

# -----------------------------------------------------------------------------
# Shell / REPL history
# -----------------------------------------------------------------------------
.bash_history
.zsh_history
.python_history
.psql_history
.lesshst
.viminfo
.node_repl_history

# -----------------------------------------------------------------------------
# Caches / build / runtime
# -----------------------------------------------------------------------------
node_modules/
__pycache__/
.venv/
venv/
*.sqlite
*.db

# -----------------------------------------------------------------------------
# OS junk
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Local-only baseline pointers (symlinks created by capture-all.sh — not tracked)
# -----------------------------------------------------------------------------
baselines/*/latest
